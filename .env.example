# ============================================================
# Job Scheduler Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# Cassandra
CASSANDRA_HOSTS=localhost
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=job_scheduler
CASSANDRA_REPLICATION_FACTOR=1

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Queue
QUEUE_PENDING_KEY=queue:pending
QUEUE_PROCESSING_KEY=queue:processing
QUEUE_VISIBILITY_TIMEOUT=30
QUEUE_HEARTBEAT_INTERVAL=15

# Scheduler
SCHEDULER_POLL_INTERVAL=300
SCHEDULER_LOOKAHEAD_SECONDS=360

# Worker
WORKER_CONCURRENCY=10
WORKER_MAX_RETRIES=3
WORKER_RETRY_BASE_DELAY=5

# API
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO
